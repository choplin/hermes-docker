# =============================================================================
# Hermes Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before building the container.

# ---------------------------------------------------------------------------
# Container User
# ---------------------------------------------------------------------------
# UID/GID for the 'hermes' user inside the container.
# Find your desired values with:  id $USER
HERMES_UID=1026
HERMES_GID=100

# ---------------------------------------------------------------------------
# LLM Provider — OpenCode Go
# ---------------------------------------------------------------------------
# OpenCode Go provides access to open models (Kimi K2.6, DeepSeek V4 Flash,
# GLM-5, MiniMax M2.5, etc.) for a flat $10/month subscription.
# Get your key at: https://opencode.ai/auth
OPENCODE_GO_API_KEY=

# ---------------------------------------------------------------------------
# Bootstrap Settings (used by entrypoint.sh on first start)
# ---------------------------------------------------------------------------
HERMES_BOOTSTRAP_PROVIDER=opencode-go
HERMES_BOOTSTRAP_MODEL=kimi-k2.6
HERMES_BOOTSTRAP_ON_START=1

# ---------------------------------------------------------------------------
# Dashboard Authentication (Basic Auth)
# ---------------------------------------------------------------------------
# The dashboard refuses to bind to 0.0.0.0 without an auth provider.
# Set credentials below to enable basic auth (plaintext is hashed in memory).
# For OAuth (Nous Portal), run `hermes dashboard register` after first start
# and remove these vars.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=changeme
